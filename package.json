{
  "name": "@jabezpauls/md-converter",
  "version": "1.0.0",
  "description": "Convert Markdown to DOCX, PDF, TXT, or HTML",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "md-converter": "./dist/cli/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli/index.js",
    "server": "node dist/api/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "markdown",
    "docx",
    "pdf",
    "html",
    "converter",
    "md",
    "gfm",
    "markdown-to-docx",
    "markdown-to-pdf",
    "markdown-converter",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jabezpauls/md-converter.git"
  },
  "bugs": {
    "url": "https://github.com/jabezpauls/md-converter/issues"
  },
  "homepage": "https://github.com/jabezpauls/md-converter#readme",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "docx": "^9.0.2",
    "fastify": "^5.1.0",
    "ora": "^8.1.1",
    "puppeteer-core": "^23.9.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.1",
    "shiki": "^1.23.1",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.6"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
